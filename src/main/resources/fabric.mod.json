{
	"schemaVersion": 1,
	"id": "minihud-mspt-provider",
	"version": "${version}",
	"name": "MiniHUD MSPT Provider",
	"description": "A very simple server-side mod to provide live TPS and MSPT data to clients running MiniHUD.",
	"authors": [
		"Dave Pusey"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/minihud-mspt-provider",
		"sources": "https://github.com/davepusey/minihud-mspt-provider"
	},
	"license": "CC0-1.0",
	"icon": "assets/minihud-mspt-provider/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"davepusey.minihudmsptprovider.MiniHUDMSPTProvider"
		]
	},
	"mixins": [
		"minihud-mspt-provider.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": "~26.1",
		"java": "25",
		"fabric-api": ">=0.144.3+26.1"
	}
}